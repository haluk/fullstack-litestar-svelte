# Postgres
POSTGRES_DB={{ db_name }}
POSTGRES_USER={{ db_user }}
POSTGRES_PASSWORD=changeme

# Application
BACKEND_PORT={{ backend_port }}
FRONTEND_PORT={{ frontend_port }}
DOMAIN={{ domain }}
JWT_SECRET=change-me-in-production

# Backend database connection (async) — set the password to match POSTGRES_PASSWORD.
# Host/port are for running the backend on your machine or against an external DB;
# inside Docker Compose the api uses the internal 'db' service instead.
# (If port {{ db_port }} is already used by a local Postgres, regenerate with a different db_port.)
DATABASE_URL=postgresql+asyncpg://{{ db_user }}:changeme@{{ db_host }}:{{ db_port }}/{{ db_name }}

# Deployment (prod)
ORIGIN=http://{{ domain }}
INTERNAL_API_URL=http://api:8000
