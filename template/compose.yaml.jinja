services:
  db:
    image: postgres:alpine
    environment:
      POSTGRES_DB: {{ db_name }}
      POSTGRES_USER: {{ db_user }}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-changeme}
    volumes:
      - db_data:/var/lib/postgresql
    ports:
      # expose Postgres on the host so localhost:{{ db_port }} (from .env) works for host-based runs
      - "{{ db_port }}:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ db_user }} -d {{ db_name }}"]
      interval: 5s
      timeout: 5s
      retries: 5

  api:
    image: ghcr.io/astral-sh/uv:python3.14-trixie-slim
    working_dir: /app
    depends_on:
      db:
        condition: service_healthy
    environment:
      DATABASE_URL: postgresql+asyncpg://{{ db_user }}:${POSTGRES_PASSWORD:-changeme}@db:5432/{{ db_name }}
      JWT_SECRET: ${JWT_SECRET:-change-me-in-production}
      LITESTAR_APP: {{ package_name }}.app:app
    volumes:
      - ./backend:/app
    command: sh -c "uv sync && uv run litestar database upgrade --no-prompt && uv run litestar run --host 0.0.0.0 --port 8000 --reload"
    ports:
      - "{{ backend_port }}:8000"

  web:
    image: oven/bun:1-slim
    working_dir: /app
    depends_on:
      - api
    environment:
      VITE_API_PROXY: http://api:8000
    volumes:
      - ./frontend:/app
    command: sh -c "bun install && bun run dev --host 0.0.0.0 --port 3000"
    ports:
      - "{{ frontend_port }}:3000"

volumes:
  db_data:
