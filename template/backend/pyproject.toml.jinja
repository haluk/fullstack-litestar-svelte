[project]
name = "{{ package_name }}"
version = "0.1.0"
description = "{{ project_name }} backend (Litestar)"
requires-python = ">={{ python_version }}"
dependencies = [
    "litestar[standard,jwt]>=2.24,<3",
    "advanced-alchemy>=1.11.0",
    "asyncpg>=0.31.0",
    "pydantic-settings>=2.14.2",
    "pwdlib[argon2]>=0.3.0",
    "msgspec>=0.21.1",
]

[dependency-groups]
dev = [
    "pytest>=9.1.1",
    "pytest-asyncio>=0.24",
    "testcontainers>=4.14.2",
    "ruff>=0.15.21",
    "mypy>=2.2.0",
    "pre-commit>=4.6.0",
    "deptry>=0.25.1",
]

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]
markers = ["integration: needs a database (testcontainers Postgres)"]
filterwarnings = [
    # Litestar 2.24 forward-compat deprecations for inferred DI / path params.
    # Migrate to NamedDependency / FromPath when upgrading to Litestar 3.0.
    "ignore:.*Inferred dependency field.*",
    "ignore:.*deprecated inferred style.*",
    # Upstream advanced-alchemy calls its own deprecated set_async_context (removed upstream in 2.0).
    "ignore:.*set_async_context.*",
]

[tool.ruff]
target-version = "py{{ python_version | replace('.', '') }}"
line-length = 100

[tool.mypy]
python_version = "{{ python_version }}"
ignore_missing_imports = true

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]
