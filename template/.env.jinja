# Generated with your answers. This file is git-ignored — keep real secrets here.
# Postgres
POSTGRES_DB={{ db_name }}
POSTGRES_USER={{ db_user }}
POSTGRES_PASSWORD={{ db_password }}

# Application
BACKEND_PORT={{ backend_port }}
FRONTEND_PORT={{ frontend_port }}
DOMAIN={{ domain }}

# Backend database connection (async).
# Host/port are for running the backend on your machine or against an external DB;
# inside Docker Compose the api uses the internal 'db' service instead.
DATABASE_URL=postgresql+asyncpg://{{ db_user }}:{{ db_password }}@{{ db_host }}:{{ db_port }}/{{ db_name }}

# Deployment (prod)
ORIGIN=http://{{ domain }}
INTERNAL_API_URL=http://api:8000
