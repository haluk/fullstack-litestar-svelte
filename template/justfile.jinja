set dotenv-load := true

# {{ project_name }} — task runner

default:
	@just --list

# install backend + frontend deps
bootstrap:
	cd backend && uv sync
	cd frontend && bun install

# --- local (host) development: run api + web on your machine against the dockerized db ---

# start only Postgres (for host-based backend/frontend runs)
db:
	docker compose up -d db

# apply migrations to the local db (reads DATABASE_URL from .env, e.g. localhost)
be-upgrade:
	cd backend && LITESTAR_APP={{ package_name }}.app:app uv run litestar database upgrade --no-prompt

# run the backend on your machine with autoreload (http://localhost:${BACKEND_PORT})
be-run:
	cd backend && LITESTAR_APP={{ package_name }}.app:app uv run litestar run --reload --port "${BACKEND_PORT}"

# run the frontend dev server on your machine
# SvelteKit SSR (e.g. the login form action) fetches the API via INTERNAL_API_URL.
# The .env value (http://api:8000) is the docker-internal host and is unreachable
# here, so point it at the backend on localhost. (Browser /api calls use Vite's proxy.)
fe-run:
	cd frontend && INTERNAL_API_URL=http://localhost:${BACKEND_PORT} bun run dev --host localhost --port "${FRONTEND_PORT}"

# --- dockerized development ---

# dev stack (postgres + api reload + web dev)
dev:
	docker compose up

up:
	docker compose up -d

down:
	docker compose down

# production stack (nginx + web + api + db)
prod:
	docker compose -f compose.prod.yaml up -d --build

prod-down:
	docker compose -f compose.prod.yaml down

# database migrations (advanced-alchemy / alembic via litestar CLI)
migrate:
	docker compose exec api uv run litestar database upgrade

makemigration message:
	docker compose exec api uv run litestar database make-migrations -m "{% raw %}{{ message }}{% endraw %}"

# lint + format
lint:
	cd backend && uv run ruff check .
	cd frontend && bun run check

fmt:
	cd backend && uv run ruff format .

# code quality tools
check:
	@echo "Checking lock file consistency with 'pyproject.toml'"
	cd backend && uv lock --locked
	@echo "Linting code: Running pre-commit"
	cd backend && uv run pre-commit run -a
	@echo "Static type checking: Running mypy"
	cd backend && uv run mypy
	@echo "Checking for obsolete dependencies: Running deptry"
	cd backend && uv run deptry .

# tests
be-test:
	cd backend && uv run python -m pytest --cov --cov-config=pyproject.toml --cov-report=xml tests

fe-test:
	cd frontend && bun run test:unit

test: be-test fe-test

# build images
build:
	docker compose -f compose.prod.yaml build
